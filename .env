# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=master_db
DB_USER=master_user
DB_PASSWORD=
DATABASE_URL=postgresql://localhost:5432/master_db

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT
JWT_SECRET=
JWT_REFRESH_SECRET=
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d

# App
NODE_ENV=production
PORT=3000
API_VERSION=v1

# Media
UPLOAD_DIR=/opt/master/uploads
MAX_FILE_SIZE=10485760

# CORS — замени на свой домен
ALLOWED_ORIGINS=https://api.it-trend.dev

#DeepSeak
DEEPSEEK_API_KEY=

# App
PORT=3000
API_VERSION=v1

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=master_db
DB_USER=master_user
DB_PASSWORD=
DATABASE_URL=postgresql://localhost:5432/master_db

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT
JWT_SECRET=
JWT_REFRESH_SECRET=
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d

# OTP
OTP_EXPIRES_IN=300
# В dev режиме OTP всегда 123456, в prod нужен SMS провайдер
SMS_PROVIDER=mock
# SMS_API_KEY=your_sms_key
# SMS_SENDER=MASTER

# Media
UPLOAD_DIR=/opt/master/uploads
MAX_FILE_SIZE=10485760
CDN_URL=https://api.it-trend.dev/uploads

# CORS
ALLOWED_ORIGINS=http://localhost:3000,https://api.it-trend.dev

# Whisper (для AI транскрипции)
WHISPER_URL=http://whisper.it-trend.dev:8000
NODE_ENV=development

OLLAMA_URL=http://whisper.it-trend.dev:11434
